# Copie esse arquivo para .env.local e preencha com as suas chaves.
# O .env.local fica no .gitignore — nunca commite credenciais no GitHub.

# Supabase — pegar em supabase.com > seu projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bling ERP — Configuracoes > API > novo app OAuth2
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=

# Mercado Pago — developers.mercadopago.com > suas credenciais
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Frenet — frenet.com.br > minha conta > API
FRENET_TOKEN=

# Resend — resend.com > API Keys
RESEND_API_KEY=

# URL publica do site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Segredo do Vercel Cron que reseta os dados demo 1x/dia (rota /api/demo/reset).
# Gere um valor aleatorio (ex.: openssl rand -hex 16) e cadastre na Vercel.
CRON_SECRET=
